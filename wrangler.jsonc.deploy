{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "my-hermes-agnt",
  "compatibility_date": "2026-05-03",
  "pages_build_output_dir": "./dist",
  "compatibility_flags": [
    "nodejs_compat"
  ],

  // Workers AI — free edge LLM (fallback) + bge embeddings (V3 semantic recall).
  // Enabled for production deploy (runs remotely on CF edge).
  "ai": {
    "binding": "AI"
  },

  // KV — raw persistent memory across sessions (God Mode V2 core).
  "kv_namespaces": [
    {
      "binding": "HERMES_MEM",
      "id": "8a114a83951b40e7bb19d92f6ef3bc7a",
      "preview_id": "827872f2152645b89bf2e4970bb58ec6"
    }
  ],

  // God Mode V3: Vectorize semantic recall (bge-large 1024d, cosine).
  // Enabled for production deploy. Code degrades gracefully to KV keyword
  // recall if this index is ever unavailable.
  "vectorize": [
    {
      "binding": "HERMES_VEC",
      "index_name": "hermes-memory-index"
    }
  ]
}
